# CryptoDistro 2.0 — Environment Variables
# Copy to .env and fill in your keys. Never commit .env.

# Binance (CEX execution leg)
BINANCE_API_KEY=
BINANCE_API_SECRET=

# Noones (P2P platform)
NOONES_API_KEY=
NOONES_API_SECRET=

# Telegram alerts
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Cerebras inference (LLM chat agent)
CEREBRAS_API_KEY=

# CoinMarketCap (analytics page)
COINMARKETCAP_API_KEY=

# Frontend — Next.js public env (prefix required)
NEXT_PUBLIC_CMC_KEY=
